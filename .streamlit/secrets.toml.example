# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────
# DO NOT COMMIT THIS FILE — it is listed in .gitignore
# Add these values in Streamlit Cloud → App Settings → Secrets
# or in Railway/Render as Environment Variables
# ─────────────────────────────────────────────────────────────

# Your Modal token (get from: modal token new)
MODAL_TOKEN_ID     = "ak-xxxxxxxxxxxxxxxxxxxx"
MODAL_TOKEN_SECRET = "as-xxxxxxxxxxxxxxxxxxxx"

# Optional: pre-set Modal workspace name
MODAL_WORKSPACE    = "your-modal-username"

# Optional: direct HTTP endpoint URL from Modal dashboard
MODAL_HTTP_ENDPOINT = "https://your-workspace--xtts-api.modal.run"
